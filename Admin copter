-- PÁGINA 1: AÇÕES
local function buildAcoes()
    clearContent()
    local dropLabel = createPlayerDropdown(contentScroll)

    getSectionLabel(contentScroll, "Ações", "⚡")

    getActionRow(contentScroll, "Kill", function()
        if selectedPlayer and selectedPlayer.Character then
            local hum = selectedPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.Health = 0 end
        end
    end)

    getActionRow(contentScroll, "Kill All", function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = 0 end
            end
        end
    end)

    getActionRow(contentScroll, "Kick", function()
        if selectedPlayer then
            selectedPlayer:Kick("Kickado pelo admin!")
        end
    end)

    getActionRow(contentScroll, "Kick All", function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player then
                p:Kick("Kickado pelo admin!")
            end
        end
    end)

    getActionRow(contentScroll, "Freeze", function()
        if selectedPlayer and selectedPlayer.Character then
            local root = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then root.Anchored = true end
        end
    end)

    getActionRow(contentScroll, "Freeze All", function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then root.Anchored = true end
            end
        end
    end)

    getActionRow(contentScroll, "Unfreeze", function()
        if selectedPlayer and selectedPlayer.Character then
            local root = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then root.Anchored = false end
        end
    end)

    getActionRow(contentScroll, "Unfreeze All", function()
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then root.Anchored = false end
            end
        end
    end)
end

-- PÁGINA 2: MOVIMENTAÇÃO
local function buildMovimento()
    clearContent()
    createPlayerDropdown(contentScroll)
    getSectionLabel(contentScroll, "Movimentação", "🎯")

    getActionRow(contentScroll, "TP to Player", function()
        if selectedPlayer and selectedPlayer.Character then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local tRoot = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root and tRoot then
                root.CFrame = tRoot.CFrame + Vector3.new(3,0,0)
            end
        end
    end)

    getActionRow(contentScroll, "View Player", function()
        if selectedPlayer and selectedPlayer.Character then
            workspace.CurrentCamera.CameraSubject = selectedPlayer.Character
        end
    end)

    getActionRow(contentScroll, "View Reset", function()
        workspace.CurrentCamera.CameraSubject = player.Character
    end)

    getSectionLabel(contentScroll, "Movimento Próprio", "🏃")

    getToggleRow(contentScroll, "Speed Boost", function(state)
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = state and 80 or 16 end
    end)

    getToggleRow(contentScroll, "Noclip", function(state)
        RunService.Stepped:Connect(function()
            if state and player.Character then
                for _, p in pairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end)

    getToggleRow(contentScroll, "Inf Jump", function(state)
        UserInputService.JumpRequest:Connect(function()
            if state then
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
            end
        end)
    end)
end

