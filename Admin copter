local function buildFerramentas()
    clearContent()
    getSectionLabel(contentScroll, "Ferramentas", "🛠️")

    getToggleRow(contentScroll, "Modo Delete (Clique)", function(state)
        local mouse = player:GetMouse()
        local conn
        if state then
            conn = mouse.Button1Down:Connect(function()
                if mouse.Target then
                    pcall(function() Events.Delete:FireServer(mouse.Target) end)
                end
            end)
        else
            if conn then conn:Disconnect() end
        end
    end)

    getActionRow(contentScroll, "Purge Map", function()
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Locked == false then
                pcall(function() Events.Delete:FireServer(obj) end)
            end
        end
    end)

    getActionRow(contentScroll, "Refresh Jogadores", function()
        selectedPlayer = nil
    end)

    getToggleRow(contentScroll, "ESP Jogadores", function(state)
        local highlights = {}
        if state then
            RunService.Heartbeat:Connect(function()
                if not state then return end
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character then
                        if not highlights[p.Name] then
                            local h = Instance.new("Highlight")
                            h.FillColor = Color3.fromRGB(255,0,0)
                            h.OutlineColor = Color3.fromRGB(255,255,255)
                            h.FillTransparency = 0.5
                            h.Parent = p.Character
                            highlights[p.Name] = h
                        end
                    end
                end
            end)
        else
            for _, h in pairs(highlights) do
                if h then h:Destroy() end
            end
            highlights = {}
        end
    end)

    getToggleRow(contentScroll, "God Mode", function(state)
        RunService.Heartbeat:Connect(function()
            if state then
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = hum.MaxHealth end
            end
        end)
    end)
end

