local function createPlayerDropdown(parent)
    getSectionLabel(parent, "Jogador Alvo", "👤")

    local dropFrame = Instance.new("Frame")
    dropFrame.Size = UDim2.new(1, 0, 0, 40)
    dropFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 26)
    dropFrame.BorderSizePixel = 0
    dropFrame.Parent = parent
    local dfc = Instance.new("UICorner")
    dfc.CornerRadius = UDim.new(0, 8)
    dfc.Parent = dropFrame
    local dfs = Instance.new("UIStroke")
    dfs.Thickness = 1
    dfs.Color = Color3.fromRGB(30, 30, 45)
    dfs.Parent = dropFrame

    local dropLabel = Instance.new("TextLabel")
    dropLabel.Size = UDim2.new(1, -40, 1, 0)
    dropLabel.Position = UDim2.new(0, 12, 0, 0)
    dropLabel.BackgroundTransparency = 1
    dropLabel.Text = "Selecione um jogador  --"
    dropLabel.TextColor3 = Color3.fromRGB(120, 120, 140)
    dropLabel.TextSize = 13
    dropLabel.Font = Enum.Font.SourceSans
    dropLabel.TextXAlignment = Enum.TextXAlignment.Left
    dropLabel.Parent = dropFrame

    local dropBtn = Instance.new("TextButton")
    dropBtn.Size = UDim2.new(0, 30, 0, 30)
    dropBtn.Position = UDim2.new(1, -36, 0, 5)
    dropBtn.BackgroundColor3 = Color3.fromRGB(0, 80, 200)
    dropBtn.Text = "⌄"
    dropBtn.TextSize = 14
    dropBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropBtn.Font = Enum.Font.SourceSansBold
    dropBtn.Parent = dropFrame
    local dbc = Instance.new("UICorner")
    dbc.CornerRadius = UDim.new(0, 6)
    dbc.Parent = dropBtn

    local playerListFrame = Instance.new("Frame")
    playerListFrame.Size = UDim2.new(1, 0, 0, 0)
    playerListFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
    playerListFrame.BorderSizePixel = 0
    playerListFrame.Visible = false
    playerListFrame.Parent = parent
    local plc = Instance.new("UICorner")
    plc.CornerRadius = UDim.new(0, 8)
    plc.Parent = playerListFrame
    Instance.new("UIListLayout").Parent = playerListFrame

    local function refreshList()
        for _, c in pairs(playerListFrame:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        local count = 0
        for _, p in pairs(Players:GetPlayers()) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 34)
            btn.BackgroundTransparency = 1
            btn.Text = "  " .. p.DisplayName .. " (" .. p.Name .. ")"
            btn.TextColor3 = p == player and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(200, 200, 210)
            btn.TextSize = 12
            btn.Font = Enum.Font.SourceSans
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.Parent = playerListFrame
            btn.Activated:Connect(function()
                selectedPlayer = p
                dropLabel.Text = p.DisplayName .. " (" .. p.Name .. ")"
                dropLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
                playerListFrame.Visible = false
                playerListFrame.Size = UDim2.new(1, 0, 0, 0)
            end)
            count = count + 1
        end
        playerListFrame.Size = UDim2.new(1, 0, 0, count * 34)
    end

    dropBtn.Activated:Connect(function()
        refreshList()
        playerListFrame.Visible = not playerListFrame.Visible
    end)

    return dropLabel
end

